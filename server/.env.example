# Second Brain — server config (ARCHITECTURE.md §11). Copy to .env; never commit .env.

# Postgres connection (Neon / Railway / Fly / local Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/secondbrain?schema=public"

# JWT (access + refresh) — use long random strings; rotate in prod
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_TTL="30d"

# Server
PORT=3000
